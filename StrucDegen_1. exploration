    "# ==============================================================\n",
    "# 9. 渗流实验（Percolation Test）\n",
    "# ==============================================================\n",
    "\n",
    "def run_percolation_scan(A_true, X_obs, sparsity_range, k_modes=5):\n",
    "    \"\"\"\n",
    "    渗流扫描：从高保留比例到低保留比例逐步截断网络，\n",
    "    记录谱半径变化、救援状态及与基准矩阵的结构/功能相似度。\n",
    "\n",
    "    算法逻辑（每个稀疏度下）：\n",
    "    1. 按 A_eff 能量大小保留前 sp 比例的边，得到 A_skeleton；\n",
    "    2. 若 A_skeleton 谱半径为零（DAG），按能量从大到小逐条加回边，\n",
    "       直到谱半径恢复（Rescued）；若加满 200 条仍无效则标记为 Broken；\n",
    "    3. 记录相变快照：濒死前一刻（just_connected）、\n",
    "       首次断裂（just_broken）、被救回（rescued）。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    A_true        : np.ndarray (N, N)\n",
    "    X_obs         : np.ndarray (T, N)  观测轨迹，用于提取动力学子空间\n",
    "    sparsity_range: array-like          保留边比例列表（顺序任意，内部自动降序处理）\n",
    "    k_modes       : int                 动力学子空间维度 k（默认 5）\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    results      : list of dict，每项含：\n",
    "                   sparsity / rho_natural / rho_final /\n",
    "                   is_rescued / edges_added /\n",
    "                   struct_sim_true / struct_sim_lasso /（lasso 列仅在传入时有效）\n",
    "                   core_sim_true / core_sim_lasso / state\n",
    "    snapshots    : dict {'just_connected', 'just_broken', 'rescued'}\n",
    "    critical_sp  : float  首次断裂时的稀疏度（-1 表示未发生断裂）\n",
    "    A_eff        : np.ndarray (N, N)  用于后续分析\n",
    "    U_dyn        : np.ndarray (N, k)  动力学子空间基底\n",
    "    \"\"\"\n",
    "    print(f\"提取动力学子空间（k={k_modes}）...\")\n",
    "    U_dyn = extract_dynamical_basis(X_obs, energy_threshold=0.98, min_k=k_modes)\n",
    "    # 若 SVD 返回的维度不足 k_modes，取实际值\n",
    "    U_dyn    = U_dyn[:, :k_modes] if U_dyn.shape[1] >= k_modes else U_dyn\n",
    "    A_eff    = compute_effective_matrix(A_true, U_dyn)\n",
    "    energies = np.abs(A_eff)\n",
    "\n",
    "    core_true = compute_core_matrix(A_true, U_dyn)\n",
    "\n",
    "    # 确保降序扫描（从稠密 → 稀疏）\n",
    "    sp_sorted = np.sort(np.unique(sparsity_range))[::-1]\n",
    "    print(f\"扫描范围：{sp_sorted[0]:.1%} → {sp_sorted[-1]:.1%}，共 {len(sp_sorted)} 个点\")\n",
    "\n",
    "    results     = []\n",
    "    snapshots   = {'just_connected': None, 'just_broken': None, 'rescued': None}\n",
    "    critical_sp = -1\n",
    "\n",
    "    for sp in sp_sorted:\n",
    "        # A. 截断\n",
    "        if sp >= 1.0:\n",
    "            mask_keep = np.ones_like(energies, dtype=bool)\n",
    "        else:\n",
    "            threshold = np.percentile(energies, 100 * (1 - sp))\n",
    "            mask_keep = energies >= threshold\n",
    "\n",
    "        A_curr = np.zeros_like(A_true)\n",
    "        A_curr[mask_keep] = A_eff[mask_keep]\n",
    "\n",
    "        # B. 检查自然连通性\n",
    "        rho_natural       = float(np.max(np.abs(np.linalg.eigvals(A_curr))))\n",
    "        is_naturally_conn = rho_natural > 1e-9\n",
    "        is_rescued        = False\n",
    "        edges_added       = 0\n",
    "\n",
    "        if not is_naturally_conn:\n",
    "            # 尝试按能量从大到小加回边\n",
    "            mask_rem  = (energies > 1e-9) & (~mask_keep)\n",
    "            cands     = sorted(\n",
    "                [(energies[r, c], r, c)\n",
    "                 for r, c in zip(*np.where(mask_rem))],\n",
    "                reverse=True\n",
    "            )\n",
    "            A_tmp = A_curr.copy()\n",
    "            for i, (_, r, c) in enumerate(cands[:200]):\n",
    "                A_tmp[r, c] = A_eff[r, c]\n",
    "                if np.max(np.abs(np.linalg.eigvals(A_tmp))) > 1e-9:\n",
    "                    A_curr      = A_tmp\n",
    "                    is_rescued  = True\n",
    "                    edges_added = i + 1\n",
    "                    break\n",
    "\n",
    "        rho_final    = float(np.max(np.abs(np.linalg.eigvals(A_curr))))\n",
    "        current_state = (\"Natural\" if is_naturally_conn\n",
    "                         else (\"Rescued\" if is_rescued else \"Broken\"))\n",
    "\n",
    "        # C. 捕捉相变快照\n",
    "        if is_naturally_conn:\n",
    "            snapshots['just_connected'] = A_curr.copy()\n",
    "        elif snapshots['just_broken'] is None:\n",
    "            snapshots['just_broken'] = A_curr.copy()          # 首次断裂\n",
    "            snapshots['rescued']     = A_curr.copy()          # 救援后状态\n",
    "            critical_sp              = sp\n",
    "\n",
    "        # D. 相似度计算（结构 & 功能）\n",
    "        def _cosine_sim(M1, M2):\n",
    "            v1, v2 = M1.flatten(), M2.flatten()\n",
    "            n1, n2 = np.linalg.norm(v1), np.linalg.norm(v2)\n",
    "            if n1 < 1e-12 or n2 < 1e-12:\n",
    "                return 0.0\n",
    "            return float(np.dot(v1, v2) / (n1 * n2))\n",
    "\n",
    "        core_curr = compute_core_matrix(A_curr, U_dyn)\n",
    "\n",
    "        results.append({\n",
    "            'sparsity':         sp,\n",
    "            'rho_natural':      rho_natural,\n",
    "            'rho_final':        rho_final,\n",
    "            'is_rescued':       is_rescued,\n",
    "            'edges_added':      edges_added,\n",
    "            'state':            current_state,\n",
    "            'struct_sim_true':  _cosine_sim(A_curr,    A_true),\n",
    "            'core_sim_true':    _cosine_sim(core_curr, core_true),\n",
    "            'A_eff_corr':       np.corrcoef(A_curr.flatten(), A_eff.flatten())[0, 1],\n",
    "        })\n",
    "\n",
    "    print(f\"扫描完成。首次断裂稀疏度：{critical_sp:.1%}\" if critical_sp > 0\n",
    "          else \"扫描完成。在该范围内未发生断裂。\")\n",
    "    return results, snapshots, critical_sp, A_eff, U_dyn\n",
    "\n",
    "\n",
    "def find_critical_points(results):\n",
    "    \"\"\"\n",
    "    从渗流扫描结果中自动检测两个临界稀疏度：\n",
    "    - k_trigger：首次需要救援的稀疏度（Natural → Rescued）\n",
    "    - k_fail   ：救援彻底失败的稀疏度（→ Broken）\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    results : list of dict，由 run_percolation_scan 返回\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    k_trigger : float or None\n",
    "    k_fail    : float or None\n",
    "    \"\"\"\n",
    "    # 按 sparsity 降序排列（从稠密到稀疏）\n",
    "    sorted_res = sorted(results, key=lambda x: x['sparsity'], reverse=True)\n",
    "    k_trigger, k_fail = None, None\n",
    "\n",
    "    print(\"-\" * 45)\n",
    "    print(\"自动临界点检测\")\n",
    "    print(\"-\" * 45)\n",
    "    for r in sorted_res:\n",
    "        if k_trigger is None and r['state'] != 'Natural':\n",
    "            k_trigger = r['sparsity']\n",
    "            print(f\"救援触发点（Rescue Start）：k = {k_trigger:.2%}  [{r['state']}]\")\n",
    "        if k_fail is None and r['state'] == 'Broken':\n",
    "            k_fail = r['sparsity']\n",
    "            print(f\"救援失效点（System Fail） ：k = {k_fail:.2%}  [Broken]\")\n",
    "        if k_trigger is not None and k_fail is not None:\n",
    "            break\n",
    "\n",
    "    if k_trigger is None:\n",
    "        print(\"在扫描范围内网络始终自然连通，未触发救援。\")\n",
    "    if k_fail is None and k_trigger is not None:\n",
    "        print(\"救援在整个扫描范围内均成功，未观察到彻底断裂。\")\n",
    "    print(\"-\" * 45)\n",
    "    return k_trigger, k_fail\n",
    "\n",
    "\n",
    "def plot_percolation_results(results, snapshots, k_trigger, k_fail,\n",
    "                              save_path_phase=None, save_path_similarity=None):\n",
    "    \"\"\"\n",
    "    绘制渗流实验的相似度演化图（结构层面 & 功能层面），各含局部放大框。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    results              : list of dict，由 run_percolation_scan 返回\n",
    "    snapshots            : dict，由 run_percolation_scan 返回（当前未使用，保留接口）\n",
    "    k_trigger            : float or None，由 find_critical_points 返回\n",
    "    k_fail               : float or None，由 find_critical_points 返回\n",
    "    save_path_phase      : str or None  （保留参数，当前不绘制相变图，传入值会被忽略）\n",
    "    save_path_similarity : str or None  相似度图保存路径\n",
    "    \"\"\"\n",
    "    from mpl_toolkits.axes_grid1.inset_locator import mark_inset\n",
    "\n",
    "    # 按稀疏度升序整理数据（方便画线）\n",
    "    res_sorted    = sorted(results, key=lambda x: x['sparsity'])\n",
    "    sp_ax         = np.array([r['sparsity']        for r in res_sorted])\n",
    "    struct_true   = np.array([r['struct_sim_true'] for r in res_sorted])\n",
    "    core_true_sim = np.array([r['core_sim_true']   for r in res_sorted])\n",
    "    k_min         = float(sp_ax[0])\n",
    "\n",
    "    # ── 相似度演化图（含局部放大） ──\n",
    "    fig2, axes = plt.subplots(1, 2, figsize=(18, 7))\n",
    "\n",
    "    def _draw_similarity(ax, y_data, ylabel_label, title, inset_ylim, inset_xlim=(0.05, 0.0)):\n",
    "        ax.plot(sp_ax, y_data, 'k-o', ms=3, alpha=0.8, label=ylabel_label)\n",
    "        if k_trigger is not None:\n",
    "            ax.axvline(k_trigger, color='orange', ls='--', lw=1.5,\n",
    "                       label=f'救援触发 ({k_trigger:.1%})')\n",
    "            end_rescue = k_fail if k_fail is not None else k_min\n",
    "            ax.axvspan(end_rescue, k_trigger, color='gold',  alpha=0.2)\n",
    "        if k_fail is not None:\n",
    "            ax.axvline(k_fail,    color='black',  ls='--', lw=1.5,\n",
    "                       label=f'救援失效 ({k_fail:.1%})')\n",
    "            ax.axvspan(0.0, k_fail, color='gray', alpha=0.15)\n",
    "        ax.invert_xaxis()\n",
    "        ax.set_xlabel('保留边比例（稀疏度）', fontsize=12)\n",
    "        ax.set_ylabel('余弦相似度', fontsize=12)\n",
    "        ax.set_title(title, fontsize=14)\n",
    "        ax.set_ylim(-0.02, 1.05)\n",
    "        ax.legend(fontsize=10)\n",
    "        ax.grid(True, alpha=0.3)\n",
    "\n",
