    "def compute_rmse(X_true, X_pred):\n",
    "    \"\"\"计算两条轨迹（可长度不等）之间的 RMSE。\"\"\"\n",
    "    n = min(len(X_true), len(X_pred))\n",
    "    return np.sqrt(np.mean((X_true[:n] - X_pred[:n])**2))\n",
    "\n",
    "\n",
    "def evaluate_prediction_accuracy(X_true, X_pred, t_split):\n",
    "    \"\"\"\n",
    "    评估 t > t_split 部分的预测精度。\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    epsilon_t   : np.ndarray  各时刻节点平均 MAE\n",
    "    epsilon_bar : float       全局平均 MAE\n",
    "    \"\"\"\n",
    "    X_ref  = X_true[t_split:]\n",
    "    X_pred = X_pred[t_split:]\n",
    "    if len(X_ref) == 0:\n",
    "        print(\"错误：t_split >= 总长度，无预测区间。\")\n",
    "        return None, None\n",
    "    abs_err     = np.abs(X_ref - X_pred)\n",
    "    epsilon_t   = np.mean(abs_err, axis=1)\n",
    "    epsilon_bar = np.mean(abs_err)\n",
    "    return epsilon_t, epsilon_bar\n",
    "\n",
    "\n",
    "def compare_prediction_errors(X_true, pred_dict, t_split, dt=0.1, title=None,\n",
    "                               save_path=None):\n",
    "    \"\"\"\n",
    "    对比多个网络在预测区间的 MAE 时间曲线，并打印汇总表。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    X_true    : np.ndarray (T, N)\n",
    "    pred_dict : dict {label: X_pred (T, N)}\n",
    "    t_split   : int\n",
    "    dt        : float\n",
    "    title     : str, optional\n",
    "    save_path : str or None\n",
    "    \"\"\"\n",
    "    X_ref = X_true[t_split:]\n",
    "    if len(X_ref) == 0:\n",
    "        return []\n",
    "    T_future  = len(X_ref)\n",
    "    t_horizon = np.arange(T_future) * dt\n",
    "\n",
    "    # 解析标签中的数值，用于排序和着色\n",
    "    items = []\n",
    "    all_vals = []\n",
    "    for label, X_pred in pred_dict.items():\n",
    "        m_scale = re.search(r\"Scale\\s*([\\d\\.eE\\-\\+]+)x?\", label, re.IGNORECASE)\n",
    "        m_rho   = re.search(r\"rho=([\\d\\.eE\\-\\+]+)\",       label, re.IGNORECASE)\n",
    "        if m_scale:\n",
    "            val = float(m_scale.group(1)); vtype = 'Scale'\n",
    "        elif m_rho:\n",
    "            val = float(m_rho.group(1));   vtype = 'Rho'\n",
    "        else:\n",
    "            val = 0.0; vtype = 'Unknown'\n",
    "        is_base = \"auto\" in label.lower() or (vtype == 'Scale' and abs(val - 1.0) < 1e-6)\n",
    "        items.append({'val': val, 'label': label, 'data': X_pred, 'is_base': is_base})\n",
    "        if val > 0:\n",
    "            all_vals.append(val)\n",
    "    items.sort(key=lambda x: x['val'])\n",
    "\n",
    "    norm = mcolors.LogNorm(vmin=min(all_vals), vmax=max(all_vals)) if all_vals else None\n",
    "    cmap = plt.get_cmap('jet') if norm else None\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(12, 7))\n",
    "    records  = []\n",
    "    print(f\"{'Label':<42} | {'Mean MAE':>10} | {'Final MAE':>10}\")\n",
    "    print(\"-\" * 68)\n",
    "\n",
    "    for item in items:\n",
    "        Xp    = item['data'][t_split:]\n",
    "        n     = min(len(Xp), T_future)\n",
    "        ref   = X_ref[:n]\n",
    "        Xp    = Xp[:n]\n",
    "        t_ax  = t_horizon[:n]\n",
    "        eps_t = np.mean(np.abs(ref - Xp), axis=1)\n",
    "        mean_mae  = float(np.mean(eps_t))\n",
    "        final_mae = float(eps_t[-1]) if len(eps_t) else 0.0\n",
    "\n",
    "        records.append({'label': item['label'], 'value': item['val'],\n",
    "                        'mean_mae': mean_mae, 'final_mae': final_mae,\n",
    "                        'is_baseline': item['is_base']})\n",
    "        print(f\"{item['label']:<42} | {mean_mae:>10.6f} | {final_mae:>10.6f}\")\n",
    "\n",
    "        c  = cmap(norm(item['val'])) if (norm and item['val'] > 0) else 'gray'\n",
    "        ls = '-.' if item['is_base'] else '-'\n",
    "        lw = 2.0  if item['is_base'] else 1.5\n",
    "        lbl = (f\"★ {item['label']}\" if item['is_base'] else item['label'])\n",
    "        ax.plot(t_ax, eps_t, color=c, lw=lw, ls=ls, alpha=0.8, label=lbl)\n",
    "\n",
    "    ax.set_xlabel(r\"预测时间 $\\tilde{t}$\", fontsize=12)\n",
    "    ax.set_ylabel(r\"MAE $\\epsilon(\\tilde{t})$\", fontsize=12)\n",
