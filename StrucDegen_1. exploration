    "\n",
    "# ==============================================================\n",
    "# Cell 14：Core × Structure 二维 Slide Window 实验\n",
    "# 对应研究历程\"错配实验\"\n",
    "# 注意：这里保留实验逻辑，但在论文中定位为\"方法动机\"而非核心结论\n",
    "# ==============================================================\n",
    "def run_core_structure_scan(core_true, core_hat, A_true, A_hat, U_dyn,\n",
    "                             model, X_obs, T_train, alphas, betas):\n",
    "    \"\"\"alpha 控制 Core 混合比例，beta 控制 Structure 混合比例。\"\"\"\n",
    "    mae_matrix = np.zeros((len(alphas), len(betas)))\n",
    "    steps_pred = len(X_obs) - T_train\n",
    "    init_state = X_obs[T_train]\n",
    "\n",
    "    for i, alpha in enumerate(alphas):\n",
    "        C_mix  = alpha * core_true + (1 - alpha) * core_hat\n",
    "        A_pure = U_dyn @ C_mix @ U_dyn.T        # 反向投影（稠密网络）\n",
    "\n",
    "        for j, beta in enumerate(betas):\n",
    "            # 结构混合剪枝：beta=1 → 用 A_true 结构，beta=0 → 用 A_hat 结构\n",
    "            importance = beta * np.abs(A_true) + (1 - beta) * np.abs(A_hat)\n",
    "            n_target   = int(beta * np.sum(np.abs(A_true) > 1e-5) +\n",
    "                             (1 - beta) * np.sum(np.abs(A_hat) > 1e-5))\n",
    "            flat_imp   = importance.flatten()\n",
    "            top_idx    = np.argsort(flat_imp)[-max(n_target, 1):]\n",
    "            mask       = np.zeros_like(A_pure, dtype=bool)\n",
    "            mask[np.unravel_index(top_idx, A_pure.shape)] = True\n",
    "            A_final    = np.zeros_like(A_pure)\n",
    "            A_final[mask] = A_pure[mask]\n",
    "\n",
    "            # 能量归一化\n",
    "            norm_pure = np.linalg.norm(A_pure)\n",
    "            norm_fin  = np.linalg.norm(A_final)\n",
    "            if norm_fin > 1e-9:\n",
    "                A_final *= norm_pure / norm_fin\n",
    "\n",
    "            try:\n",
    "                X_sim = model.simulate(A_final, T_steps=steps_pred, init_state=init_state)\n",
    "                mae   = np.mean(np.abs(X_sim - X_obs[T_train:]))\n",
    "                mae   = min(mae, 2.0)\n",
    "            except Exception:\n",
    "                mae   = 2.0\n",
    "\n",
    "            mae_matrix[i, j] = mae\n",
    "        print(f\"  alpha={alpha:.2f} 完成\")\n",
    "\n",
    "    return mae_matrix\n",
    "\n",
    "alphas_scan = [-0.2, 0.0, 0.2, 0.5, 0.8, 1.0, 1.2]\n",
    "betas_scan  = [-0.2, 0.0, 0.2, 0.5, 0.8, 1.0, 1.2]\n",
    "\n",
    "mae_grid = run_core_structure_scan(\n",
    "    core_true, core_hat, A_true, A_hat_best, U_dyn,\n",
    "    model, X_obs, T_train, alphas_scan, betas_scan\n",
    ")\n",
    "\n",
    "plot_heatmap_2d_scan(mae_grid, alphas_scan, betas_scan, save_path=None)"
   ]
