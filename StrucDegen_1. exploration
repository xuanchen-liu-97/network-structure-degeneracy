    "# ==============================================================\n",
    "# Cell 5：rho scale 扫描（多个代理网络）\n",
    "# 对应研究历程中对 LASSO 鲁棒性的初步测试\n",
    "# ==============================================================\n",
    "scales         = [0.001, 0.01, 0.1, 0.5, 0.8, 1.0, 1.2, 2.0, 5.0, 10.0]\n",
    "A_hat_list     = []\n",
    "X_full_pred_list = []\n",
    "labels_scale   = []\n",
    "\n",
    "for s in scales:\n",
    "    rho_scaled = rho_hat * s\n",
    "    A_tmp, _   = reconstruct_network(X_train, model, rho=rho_scaled, threshold=0.01)\n",
    "    steps_pred = T_total - T_train\n",
    "    X_fut      = model.simulate(A_tmp, T_steps=steps_pred, init_state=x0_pred)\n",
    "    X_full     = np.vstack([X_train, X_fut])\n",
    "\n",
    "    A_hat_list.append(A_tmp)\n",
    "    X_full_pred_list.append(X_full)\n",
    "    labels_scale.append(f\"Scale {s}x\")\n",
    "\n",
    "# 误差对比图\n",
    "pred_dict = dict(zip(labels_scale, X_full_pred_list))\n",
    "records   = compare_prediction_errors(\n",
    "    X_obs, pred_dict, T_train,\n",
    "    title=\"rho Scale 扫描：预测误差\",\n",
    "    save_path=None    # 改为 'figures/scale_error.pdf' 则保存\n",
    ")\n",
    "\n",
    "# Scale vs MAE 总览\n",
    "scales_val = [r['value']    for r in records]\n",
