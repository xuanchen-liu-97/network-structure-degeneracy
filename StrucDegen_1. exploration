    "def sparsify_network_v2(A_true, U_dyn, epsilon=0.05, verbose=True):\n",
    "    \"\"\"\n",
    "    基于 A_eff 等价约束的贪心逐边删除稀疏化算法（Algorithm 2）。\n",
    "\n",
    "    与 Algorithm 1（sparsify_network）的区别：\n",
    "    - Algorithm 1：先按能量一次性截断到目标稀疏度，再救援断裂回路；\n",
    "    - Algorithm 2：逐边尝试删除，只要 A_eff 偏差不超过 epsilon 就接受，\n",
    "      否则保留该边，直到遍历所有边，最终保留的是对 A_eff 贡献最大的边集合。\n",
    "\n",
    "    算法流程：\n",
    "    1. 计算 A_eff_ref = P @ A_true @ P 作为功能基准；\n",
    "    2. 将所有边按 A_eff 能量从小到大排队（低能量边优先尝试删除）；\n",
    "    3. 逐边尝试删除：若删后 A_eff 偏差 δ < epsilon，接受删除；否则保留；\n",
    "    4. 遍历结束后对谱半径归一化。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    A_true  : np.ndarray (N, N)   原始网络\n",
    "    U_dyn   : np.ndarray (N, k)   动力学子空间基底（列正交归一）\n",
    "    epsilon : float               A_eff 相对偏差容忍上限（建议 0.01~0.10）\n",
    "    verbose : bool                是否打印进度日志\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    A_sparse         : np.ndarray (N, N)   稀疏化后的网络（谱半径已归一化）\n",
    "    deletion_history : list of dict        每步记录：\n",
    "                       step / edge / delta / accepted / n_edges\n",
    "    \"\"\"\n",
    "    rho_true  = float(np.max(np.abs(np.linalg.eigvals(A_true))))\n",
    "    A_eff_ref = compute_effective_matrix(A_true, U_dyn)\n",
    "\n",
    "    # 按 A_eff 能量从小到大排列所有非零边\n",
    "    rows, cols = np.where(np.abs(A_true) > 1e-9)\n",
    "    energies   = np.abs(A_eff_ref[rows, cols])\n",
    "    order      = np.argsort(energies)\n",
    "    edge_queue = [(rows[o], cols[o]) for o in order]\n",
    "\n",
    "    A_current        = A_true.copy()\n",
    "    deletion_history = []\n",
    "    n_deleted        = 0\n",
    "    n_protected      = 0\n",
    "    total            = len(edge_queue)\n",
    "\n",
    "    if verbose:\n",
    "        print(f\"稀疏化 v2 开始：共 {total} 条边，epsilon={epsilon}\")\n",
    "        print(f\"{'步骤':>5}  {'边':>10}  {'δ':>8}  {'决策':>6}  {'剩余边数':>8}\")\n",
    "        print(\"─\" * 50)\n",
    "\n",
    "    for step, (i, j) in enumerate(edge_queue):\n",
    "        A_tmp  = A_current.copy()\n",
    "        A_tmp[i, j] = 0.0\n",
    "        delta  = _aeff_deviation(A_tmp, A_eff_ref, U_dyn)\n",
    "        accepted = delta < epsilon\n",
    "\n",
    "        deletion_history.append({\n",
    "            \"step\":     step,\n",
    "            \"edge\":     (i, j),\n",
    "            \"delta\":    delta,\n",
    "            \"accepted\": accepted,\n",
    "            \"n_edges\":  int(np.sum(np.abs(A_current) > 1e-9)),\n",
    "        })\n",
    "\n",
    "        if accepted:\n",
    "            A_current = A_tmp\n",
    "            n_deleted += 1\n",
    "        else:\n",
    "            n_protected += 1\n",
    "\n",
    "        if verbose and (step % max(1, total // 20) == 0 or not accepted):\n",
    "            status  = \"删除✓\" if accepted else \"保护✗\"\n",
    "            n_rem   = int(np.sum(np.abs(A_current) > 1e-9))\n",
    "            print(f\"{step:>5}  ({i:>3},{j:>3})  {delta:>8.4f}  {status:>6}  {n_rem:>8}\")\n",
    "\n",
    "    # 谱半径归一化\n",
    "    rho_curr = float(np.max(np.abs(np.linalg.eigvals(A_current))))\n",
    "    if rho_curr > 1e-9:\n",
    "        A_sparse = A_current * (rho_true / rho_curr)\n",
    "    else:\n",
    "        # 退化回退：从 history 中重建最后一个谱半径 > 0 的状态\n",
    "        print(\"警告：稀疏化后谱半径为 0，尝试回退到最后有效状态…\")\n",
    "        A_rebuild = A_true.copy()\n",
    "        for rec in deletion_history:\n",
    "            if not rec[\"accepted\"]:\n",
    "                continue\n",
    "            ri, ci = rec[\"edge\"]\n",
    "            A_rebuild[ri, ci] = 0.0\n",
    "            if np.max(np.abs(np.linalg.eigvals(A_rebuild))) < 1e-9:\n",
    "                A_rebuild[ri, ci] = A_true[ri, ci]\n",
    "                break\n",
    "        rho_r   = float(np.max(np.abs(np.linalg.eigvals(A_rebuild))))\n",
    "        A_sparse = A_rebuild * (rho_true / rho_r) if rho_r > 1e-9 else A_rebuild\n",
    "\n",
    "    n_orig  = int(np.sum(np.abs(A_true)   > 1e-9))\n",
    "    n_final = int(np.sum(np.abs(A_sparse) > 1e-9))\n",
    "    if verbose:\n",
    "        print(\"─\" * 50)\n",
    "        print(f\"稀疏化 v2 完成：{n_orig} → {n_final} 条边\"\n",
    "              f\"（保留 {n_final/n_orig:.1%}，删除 {n_deleted}，保护 {n_protected}）\")\n",
    "\n",
    "    return A_sparse, deletion_history\n",
    "\n",
    "\n",
    "def summarize_sparsification_v2(A_true, A_sparse, U_dyn, deletion_history):\n",
    "    \"\"\"\n",
    "    打印 Algorithm 2 稀疏化结果的关键统计量。\n",
    "\n",
    "    指标包含：边数变化、最终 A_eff 偏差、\n",
    "    主左奇异向量对齐度（与工具库 compute_eigenvector_alignment 一致，使用 SVD）、\n",
    "    谱半径对比。\n",
    "    \"\"\"\n",
    "    A_eff_true   = compute_effective_matrix(A_true,   U_dyn)\n",
    "    A_eff_sparse = compute_effective_matrix(A_sparse, U_dyn)\n",
    "\n",
    "    n_orig  = int(np.sum(np.abs(A_true)   > 1e-9))\n",
    "    n_final = int(np.sum(np.abs(A_sparse) > 1e-9))\n",
    "    delta_f = (np.linalg.norm(A_eff_sparse - A_eff_true, 'fro') /\n",
    "               max(np.linalg.norm(A_eff_true, 'fro'), 1e-12))\n",
    "\n",
    "    # 主左奇异向量对齐度（SVD，与工具库保持一致）\n",
    "    eps_align, alignment, _, _ = compute_eigenvector_alignment(\n",
    "        A_true, A_sparse, k=1, mode='left'\n",
    "    )\n",
    "\n",
    "    print(\"══════════ 稀疏化 v2 结果摘要 ══════════\")\n",
    "    print(f\"  原始边数           : {n_orig}\")\n",
    "    print(f\"  稀疏化后边数       : {n_final}  （保留 {n_final/n_orig:.1%}）\")\n",
    "    print(f\"  最终 A_eff 偏差 δ  : {delta_f:.4f}\")\n",
    "    print(f\"  主奇异向量对齐度   : {alignment:.4f}  （1=完全对齐）\")\n",
    "    print(f\"  ε_align            : {eps_align:.4f}  （0=完全对齐）\")\n",
    "    print(f\"  谱半径 A_true      : {np.max(np.abs(np.linalg.eigvals(A_true))):.4f}\")\n",
    "    print(f\"  谱半径 A_sparse    : {np.max(np.abs(np.linalg.eigvals(A_sparse))):.4f}\")\n",
    "    print(\"════════════════════════════════════════\")\n",
    "\n",
    "\n",
    "def plot_sparsification_path_v2(deletion_history, save_path=None):\n",
    "    \"\"\"\n",
    "    绘制 Algorithm 2 稀疏化路径的三条诊断曲线：\n",
    "      左图：每步的 A_eff 偏差 δ（接受/拒绝用颜色区分）\n",
    "      中图：累计剩余边数随步骤的变化\n",
    "      右图：δ 的接受/拒绝分布直方图\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    deletion_history : list of dict，由 sparsify_network_v2 返回\n",
    "    save_path        : str or None\n",
    "    \"\"\"\n",
    "    steps    = [r[\"step\"]     for r in deletion_history]\n",
