    "    T_steps    : int                模拟步数（需足够到达稳态）\n",
    "    init_state : np.ndarray or None 初始状态；None 则随机\n",
    "    seed       : int\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    eps_macro : float  归一化序参量距离\n",
    "    phi_true  : float  A_true 的序参量\n",
    "    phi_proxy : float  A_proxy 的序参量\n",
    "    \"\"\"\n",
    "    if init_state is None:\n",
    "        np.random.seed(seed)\n",
    "        init_state = np.random.rand(model.N)\n",
    "\n",
    "    X_true  = model.simulate(A_true,  T_steps=T_steps, init_state=init_state)\n",
    "    X_proxy = model.simulate(A_proxy, T_steps=T_steps, init_state=init_state)\n",
    "\n",
    "    phi_true  = compute_order_parameter(X_true,  dyn_type)\n",
    "    phi_proxy = compute_order_parameter(X_proxy, dyn_type)\n",
    "\n",
    "    denom     = abs(phi_true) if abs(phi_true) > 1e-9 else 1.0\n",
    "    eps_macro = abs(phi_proxy - phi_true) / denom\n",
    "    return eps_macro, phi_true, phi_proxy\n",
    "\n",
    "\n",
    "def compute_eigenvector_alignment(A1, A2, k=1, mode='left'):\n",
    "    \"\"\"\n",
    "    计算两个矩阵前 k 个奇异向量子空间的对齐度（基于 SVD）。\n",
    "\n",
    "    对有向加权网络，SVD 比特征值分解更稳健（始终返回实数正交向量，\n",
    "    无需处理复数特征值）。\n",
    "\n",
    "    物理含义：\n",
    "      左奇异向量 U（mode='left'）：节点的\"响应方向\"，\n",
    "          对应动力学中 Ax ≈ σ₁ u₁(v₁ᵀx) 的响应模式，\n",
    "          与 U_dyn 框架天然兼容，适合比较 A_true 与 A_proxy。\n",
    "      右奇异向量 V（mode='right'）：节点的\"驱动方向\"。\n",
    "      两者均可（mode='both'）：取左右子空间对齐度的均值。\n",
    "\n",
    "    对齐度定义（k=1）：\n",
    "      alignment = |⟨u₁(A₁), u₁(A₂)⟩|²\n",
    "      ε_align   = 1 - alignment\n",
    "\n",
    "    对齐度定义（k>1，Grassmann 子空间角）：\n",
    "      alignment = ‖U₁ᵀ U₂‖²_F / k\n",
    "      ε_align   = 1 - alignment\n",
    "\n",
    "    设计为通用接口：A1 / A2 可以是原始邻接矩阵（N×N），\n",
    "    也可以是 core 投影矩阵（k×k），只要同维度即可。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    A1, A2 : np.ndarray  同维度方阵\n",
    "    k      : int         比较前 k 个奇异向量；k=1 即主奇异向量\n",
    "    mode   : str         'left'（默认）| 'right' | 'both'\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    eps_align  : float  对齐距离（0 = 完全对齐，1 = 完全正交）\n",
    "    alignment  : float  对齐度（1 - eps_align，越接近 1 越好）\n",
    "    svecs_A1   : np.ndarray (N, k)  A1 的前 k 个奇异向量\n",
    "    svecs_A2   : np.ndarray (N, k)  A2 的前 k 个奇异向量\n",
    "    \"\"\"\n",
    "    def top_k_svecs(A, k, side):\n",
    "        U, _, Vt = svd(A, full_matrices=False)\n",
    "        # svd 已按奇异值降序排列，直接取前 k 列/行\n",
    "        return U[:, :k] if side == 'left' else Vt[:k, :].T\n",
    "\n",
    "    def subspace_alignment(V1, V2, k):\n",
    "        cross = V1.T @ V2          # (k, k)\n",
    "        if k == 1:\n",
    "            return float(cross[0, 0]) ** 2\n",
    "        return float(np.linalg.norm(cross) ** 2) / k\n",
    "\n",
    "    if mode in ('left', 'right'):\n",
    "        V1 = top_k_svecs(A1, k, mode)\n",
    "        V2 = top_k_svecs(A2, k, mode)\n",
    "        alignment = subspace_alignment(V1, V2, k)\n",
    "        svecs_A1, svecs_A2 = V1, V2\n",
    "    else:  # 'both'：左右各算一次，取均值\n",
    "        Ul1 = top_k_svecs(A1, k, 'left');  Ul2 = top_k_svecs(A2, k, 'left')\n",
    "        Ur1 = top_k_svecs(A1, k, 'right'); Ur2 = top_k_svecs(A2, k, 'right')\n",
    "        alignment = (subspace_alignment(Ul1, Ul2, k) +\n",
    "                     subspace_alignment(Ur1, Ur2, k)) / 2.0\n",
    "        svecs_A1, svecs_A2 = Ul1, Ul2  # 返回左奇异向量作为代表\n",
    "\n",
    "    eps_align = 1.0 - alignment\n",
    "    return eps_align, alignment, svecs_A1, svecs_A2\n",
    "\n",
    "\n",
    "def scan_sparsification_degeneracy(A_true, model, dyn_type, U_dyn,\n",
    "                                   sparsity_levels, steps=20,\n",
    "                                   T_sim=500, eigvec_k=1, seed=42):\n",
    "    \"\"\"\n",
    "    沿稀疏化路径扫描序参量距离与主特征向量对齐度，用于寻找等价类边界（相变点）。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    A_true          : np.ndarray (N, N)\n",
    "    model           : NetworkDynamics\n",
    "    dyn_type        : str  见 compute_order_parameter\n",
    "    U_dyn           : np.ndarray (N, k)  动力学子空间基底\n",
    "    sparsity_levels : list of float  保留边比例（如 [0.02, 0.05, 0.10, ...]）\n",
    "    steps           : int  每次稀疏化的插值步数\n",
    "    T_sim           : int  模拟步数（需达稳态）\n",
    "    eigvec_k        : int  比较前几个特征向量（1 = 主特征向量）\n",
    "    seed            : int\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    results : list of dict，每个 dict 含：\n",
    "              sparsity / A_proxy / eps_macro / phi_true / phi_proxy /\n",
    "              eps_align / alignment\n",
    "    \"\"\"\n",
    "    np.random.seed(seed)\n",
    "    init_state = np.random.rand(model.N)\n",
    "\n",
    "    # 提前算好 A_true 的序参量（避免重复模拟）\n",
    "    X_true_sim = model.simulate(A_true, T_steps=T_sim, init_state=init_state)\n",
    "    phi_true   = compute_order_parameter(X_true_sim, dyn_type)\n",
    "\n",
    "    results = []\n",
    "    print(f\"\\n{'Sparsity':>10} | {'ε_macro':>10} | {'ε_align':>10} | {'Φ_proxy':>10}\")\n",
    "    print(\"-\" * 48)\n",
    "\n",
    "    for sp in sparsity_levels:\n",
    "        try:\n",
    "            A_proxy, _, _ = sparsify_network(A_true, U_dyn,\n",
    "                                              steps=steps, initial_sparsity=sp)\n",
    "        except RuntimeError as e:\n",
    "            print(f\"  sparsity={sp:.2f} 跳过：{e}\")\n",
    "            continue\n",
    "\n",
    "        # 序参量距离\n",
    "        X_proxy_sim = model.simulate(A_proxy, T_steps=T_sim, init_state=init_state)\n",
    "        phi_proxy   = compute_order_parameter(X_proxy_sim, dyn_type)\n",
    "        denom       = abs(phi_true) if abs(phi_true) > 1e-9 else 1.0\n",
    "        eps_macro   = abs(phi_proxy - phi_true) / denom\n",
    "\n",
    "        # 主特征向量对齐度\n",
    "        eps_align, alignment, _, _ = compute_eigenvector_alignment(A_true, A_proxy, k=eigvec_k)\n",
    "\n",
    "        results.append({\n",
    "            'sparsity':  sp,\n",
    "            'A_proxy':   A_proxy,\n",
    "            'eps_macro': eps_macro,\n",
    "            'phi_true':  phi_true,\n",
    "            'phi_proxy': phi_proxy,\n",
    "            'eps_align': eps_align,\n",
    "            'alignment': alignment,\n",
    "        })\n",
    "        print(f\"{sp:>10.3f} | {eps_macro:>10.4f} | {eps_align:>10.4f} | {phi_proxy:>10.4f}\")\n",
    "\n",
    "    return results\n",
    "\n",
    "\n",
    "def plot_degeneracy_scan(results, title=None, save_path=None):\n",
    "    \"\"\"\n",
    "    可视化稀疏化路径上的 ε_macro 和 ε_align，用于识别等价类边界（相变点）。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    results   : list of dict，由 scan_sparsification_degeneracy 返回\n",
    "    title     : str, optional\n",
    "    save_path : str or None\n",
    "    \"\"\"\n",
    "    sparsities = [r['sparsity']  for r in results]\n",
    "    eps_macro  = [r['eps_macro'] for r in results]\n",
    "    eps_align  = [r['eps_align'] for r in results]\n",
    "\n",
    "    fig, ax1 = plt.subplots(figsize=(9, 5))\n",
    "    ax2 = ax1.twinx()\n",
    "\n",
    "    ax1.plot(sparsities, eps_macro, 'r-o', lw=2, label=r'序参量距离 $\\varepsilon_{\\rm macro}$')\n",
    "    ax2.plot(sparsities, eps_align, 'b--s', lw=2, label=r'特征向量偏离度 $\\varepsilon_{\\rm align}$')\n",
    "\n",
    "    ax1.set_xlabel('保留边比例（稀疏化程度）', fontsize=12)\n",
    "    ax1.set_ylabel(r'$\\varepsilon_{\\rm macro}$（序参量距离）', color='red', fontsize=11)\n",
    "    ax2.set_ylabel(r'$\\varepsilon_{\\rm align}$（特征向量偏离度）', color='blue', fontsize=11)\n",
    "    ax1.tick_params(axis='y', labelcolor='red')\n",
    "    ax2.tick_params(axis='y', labelcolor='blue')\n",
    "\n",
    "    # 合并图例\n",
    "    h1, l1 = ax1.get_legend_handles_labels()\n",
    "    h2, l2 = ax2.get_legend_handles_labels()\n",
    "    ax1.legend(h1 + h2, l1 + l2, loc='upper left', fontsize=10)\n",
    "\n",
    "    ax1.set_title(title or '稀疏化路径上的简并性度量：寻找等价类边界', fontsize=13)\n",
    "    ax1.grid(True, alpha=0.3)\n",
