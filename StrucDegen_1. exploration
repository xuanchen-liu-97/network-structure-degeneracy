    "def _aeff_deviation(A_candidate, A_eff_ref, U_dyn):\n",
    "    A_eff_cand = compute_effective_matrix(A_candidate, U_dyn)\n",
    "    ref_norm   = np.linalg.norm(A_eff_ref, 'fro')\n",
    "    if ref_norm < 1e-12:\n",
    "        return 0.0\n",
    "    return float(np.linalg.norm(A_eff_cand - A_eff_ref, 'fro') / ref_norm)\n",
    "# ==============================================================\n",
    "# Cell 16b：Algorithm 2 稀疏化 & 与 Algorithm 1 对比\n",
    "# ==============================================================\n",
    "\n",
    "# ── 运行 Algorithm 2 ──\n",
    "# epsilon 控制 A_eff 偏差容忍度，建议先从 0.05 开始，\n",
    "# 若保留边太多可适当调大（0.08~0.10），太少可调小（0.02~0.03）\n",
    "A_proxy_v2, history_v2 = sparsify_network_v2(\n",
    "    A_true, U_dyn,\n",
    "    epsilon=0.08,\n",
    "    verbose=True\n",
    ")\n",
    "\n",
    "# ── Algorithm 2 诊断图 ──\n",
    "plot_sparsification_path_v2(history_v2, save_path=None)\n",
    "\n",
    "# ── Algorithm 2 统计摘要 ──\n",
    "summarize_sparsification_v2(A_true, A_proxy_v2, U_dyn, history_v2)\n",
    "\n",
    "# ── 动力学验证（与 Algorithm 1 同框对比）──\n",
    "steps_pred   = T_total - T_train\n",
    "X_v2_future  = model.simulate(A_proxy_v2, T_steps=steps_pred, init_state=x0_pred)\n",
    "X_v2_full    = np.vstack([X_train, X_v2_future])\n",
    "\n",
    "compare_prediction_errors(\n",
    "    X_obs,\n",
    "    {\n",
    "        \"A_hat (LASSO)\":           X_hat_full,\n",
    "        \"A_proxy v1 (截断+救援)\":  X_proxy_full,\n",
    "        \"A_proxy v2 (贪心删边)\":   X_v2_full,\n",
    "    },\n",
    "    T_train,\n",
    "    title=\"三种方法预测误差对比\",\n",
    "    save_path=None\n",
