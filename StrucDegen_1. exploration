    "'''\n",
    "Basic analysis of networks\n",
    "'''\n",
    "\n",
    "def compute_network_metrics(A, name=\"Network\", threshold=1e-5):\n",
    "    \"\"\"\n",
    "    计算网络的 SVD 分解及三种有效秩（Stable / Nuclear / Entropy）。\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    dict，含 name / U / S / Vt / ranks / topology / shape\n",
    "    \"\"\"\n",
    "    U, S, Vt = svd(A, full_matrices=False)\n",
    "    s1 = S[0] if S[0] > 1e-12 else 1.0\n",
    "    p  = S / np.sum(S); p = p[p > 1e-12]\n",
    "    srank = np.sum(S**2) / s1**2\n",
    "    nrank = np.sum(S)    / s1\n",
    "    erank = np.exp(-np.sum(p * np.log(p)))\n",
    "\n",
    "    binary = (np.abs(A) > threshold).astype(int)\n",
    "    return {\n",
    "        \"name\": name,\n",
    "        \"U\": U, \"S\": S, \"Vt\": Vt,\n",
    "        \"ranks\": {\"Stable\": srank, \"Nuclear\": nrank, \"Entropy\": erank},\n",
    "        \"topology\": {\n",
    "            \"in_degrees\":  np.sum(binary, axis=1),\n",
    "            \"num_edges\":   int(np.sum(binary)),\n",
    "            \"binary\":      binary,\n",
    "        },\n",
    "        \"shape\": A.shape,\n",
    "    }\n",
    "\n",
    "\n",
    "def align_svd_signs(U_ref, Vt_ref, U_target, Vt_target):\n",
    "    \"\"\"对齐两组 SVD 分解的符号，使列方向一致。\"\"\"\n",
    "    U_new  = U_target.copy()\n",
    "    Vt_new = Vt_target.copy()\n",
    "    for i in range(min(U_ref.shape[1], U_target.shape[1])):\n",
    "        if np.dot(U_ref[:, i], U_target[:, i]) < 0:\n",
    "            U_new[:, i]  *= -1\n",
    "            Vt_new[i, :] *= -1\n",
    "    return U_new, Vt_new\n",
    "\n",
    "\n",
    "def _save_or_show(fig, save_path):\n",
    "    \"\"\"内部辅助：若 save_path 不为 None 则保存图片，否则直接显示。\"\"\"\n",
    "    if save_path is not None:\n",
    "        fig.savefig(save_path, dpi=150, bbox_inches='tight')\n",
    "        print(f\"图片已保存至：{save_path}\")\n",
    "        plt.close(fig)\n",
    "    else:\n",
    "        plt.show()\n",
    "\n",
    "\n",
