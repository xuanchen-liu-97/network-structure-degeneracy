    "def reconstruct_network(X, model, rho=None, val_ratio=0.2, n_alphas=20, threshold=0.01):\n",
    "    \"\"\"\n",
    "    基于 LASSO 回归从时间序列重构网络邻接矩阵。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    X         : np.ndarray, shape (T, N)  节点状态时间序列\n",
    "    model     : NetworkDynamics           动力学模型对象\n",
    "    rho       : None | float | array (N,)\n",
    "                None  → 对每个节点自动 CV 搜索最优正则化强度\n",
    "                float → 所有节点使用同一固定值\n",
    "                array → 每个节点使用对应的 rho[i]\n",
    "    val_ratio : float   验证集比例（仅 rho=None 时生效）\n",
    "    n_alphas  : int     CV 搜索候选数（仅 rho=None 时生效）\n",
    "    threshold : float   硬阈值，绝对值低于此的权重置零\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    A_hat     : np.ndarray, shape (N, N)\n",
    "    rho_used  : np.ndarray, shape (N,)   各节点实际使用的 rho\n",
    "    \"\"\"\n",
    "    T, N = X.shape\n",
    "    dt = model.dt\n",
    "    if T <= 1:\n",
    "        raise ValueError(\"时间序列至少需要 2 步。\")\n",
    "\n",
    "    # --- 解析 rho 参数 ---\n",
    "    if rho is None:\n",
    "        rho_mode = 'auto'\n",
    "        print(f\"重构模式：Auto（n_alphas={n_alphas}）\")\n",
    "    elif np.isscalar(rho):\n",
    "        rho_mode = 'scalar'\n",
    "        print(f\"重构模式：Scalar（rho={rho}）\")\n",
    "    else:\n",
    "        rho_vec = np.array(rho)\n",
    "        if rho_vec.shape != (N,):\n",
    "            raise ValueError(f\"rho 数组长度 {len(rho_vec)} 与 N={N} 不符。\")\n",
    "        rho_mode = 'vector'\n",
    "        print(f\"重构模式：Vector（min={np.min(rho_vec):.2e}, max={np.max(rho_vec):.2e}）\")\n",
    "\n",
    "    # --- 准备回归数据 ---\n",
    "    X_t   = X[:-1]\n",
    "    X_tp1 = X[1:]\n",
    "    t_len = len(X_t)\n",
    "    deriv = (X_tp1 - X_t) / dt\n",
    "    f_val = model.f(X_t)\n",
    "    Y     = deriv - f_val                      # 目标：网络耦合项\n",
    "    Phi   = model.get_interaction_matrix(X_t)  # 特征：(t_len, N, N)\n",
    "\n",
    "    n_train = int(t_len * (1 - val_ratio))\n",
    "    Y_tr, Y_val     = Y[:n_train],   Y[n_train:]\n",
    "    Phi_tr, Phi_val = Phi[:n_train], Phi[n_train:]\n",
    "\n",
    "    A_hat    = np.zeros((N, N))\n",
    "    rho_used = np.zeros(N)\n",
    "\n",
    "    with warnings.catch_warnings():\n",
    "        warnings.simplefilter(\"ignore\")\n",
    "        for i in range(N):\n",
    "            Phi_tr_i  = Phi_tr[:, i, :]\n",
    "            y_tr_i    = Y_tr[:, i]\n",
    "            Phi_val_i = Phi_val[:, i, :]\n",
    "            y_val_i   = Y_val[:, i]\n",
    "\n",
    "            # 确定本节点的 rho\n",
    "            if rho_mode == 'auto':\n",
    "                dot = Phi_tr_i.T @ y_tr_i\n",
    "                rho_max = max(np.max(np.abs(dot)) / max(n_train, 1), 1e-3)\n",
    "                alphas  = np.logspace(np.log10(1e-4 * rho_max), np.log10(rho_max), n_alphas)\n",
    "                best_mse, best_alpha = np.inf, alphas[0]\n",
    "                for a in alphas:\n",
    "                    lasso = Lasso(alpha=a, fit_intercept=False, positive=True,\n",
    "                                  max_iter=2000, tol=1e-4)\n",
    "                    lasso.fit(Phi_tr_i, y_tr_i)\n",
    "                    coef = lasso.coef_.copy()\n",
    "                    coef[np.abs(coef) < threshold] = 0\n",
    "                    mse = (np.mean(y_val_i**2) if np.sum(np.abs(coef)) == 0\n",
    "                           else mean_squared_error(y_val_i, Phi_val_i @ coef))\n",
    "                    if mse < best_mse:\n",
    "                        best_mse, best_alpha = mse, a\n",
    "                final_rho = best_alpha\n",
    "            elif rho_mode == 'scalar':\n",
    "                final_rho = rho\n",
    "            else:\n",
    "                final_rho = rho_vec[i]\n",
    "\n",
    "            rho_used[i] = final_rho\n",
    "\n",
    "            # 用全量数据做最终拟合\n",
    "            lasso_f = Lasso(alpha=final_rho, fit_intercept=False, positive=True,\n",
    "                            max_iter=10000, tol=1e-4)\n",
    "            lasso_f.fit(Phi[:, i, :], Y[:, i])\n",
    "            coef = lasso_f.coef_.copy()\n",
    "            coef[np.abs(coef) < threshold] = 0\n",
    "            A_hat[i, :] = coef\n",
    "\n",
    "    if rho_mode == 'auto':\n",
    "        print(f\"重构完成，自动选择 rho 均值：{np.mean(rho_used):.4e}\")\n",
    "    return A_hat, rho_used"
   ]
