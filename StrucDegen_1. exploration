    "'''\n",
    "spacification algorithm\n",
    "'''\n",
    "\n",
    "def sparsify_network(A_true, U_dyn, steps=20, initial_sparsity=0.03):\n",
    "    \"\"\"\n",
    "    基于动力学子空间投影的绝热稀疏化算法。\n",
    "\n",
    "    算法逻辑：\n",
    "    1. 计算有效矩阵 A_eff = P @ A_true @ P，以谱能量为权重提取稀疏骨架；\n",
    "    2. 若骨架为有向无环图（无特征值），自动增加保留边比例直至出现环路；\n",
    "    3. 将骨架进行谱半径归一化，确保动力学能量尺度与 A_true 一致；\n",
    "    4. 在 steps 步内从 A_true 线性插值至骨架，每步保持谱半径守恒。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    A_true           : np.ndarray (N, N)  原始网络（稠密）\n",
    "    U_dyn            : np.ndarray (N, k)  动力学子空间基底（列正交归一）\n",
    "    steps            : int                插值步数\n",
    "    initial_sparsity : float              初始目标保留边比例（如 0.03 = 3%）\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    A_proxy  : np.ndarray (N, N)  最终稀疏化网络（路径终点）\n",
    "    history  : list of np.ndarray 中间矩阵序列（含起点 A_true 和终点 A_proxy）\n",
    "    A_skeleton : np.ndarray (N, N)  中间骨架（稀疏且谱半径已校准）\n",
    "    \"\"\"\n",
    "    print(f\"=== 稀疏化算法（steps={steps}, initial_sparsity={initial_sparsity:.1%}）===\")\n",
    "\n",
    "    P     = U_dyn @ U_dyn.T\n",
    "    A_eff = P @ A_true @ P\n",
    "    energies = np.abs(A_eff)\n",
    "\n",
    "    # 动态搜索使网络保有回路的最低稀疏度\n",
    "    current_sparsity = initial_sparsity\n",
    "    A_skeleton = None\n",
    "    rho_true   = np.max(np.abs(eigvals(A_true)))\n",
    "\n",
    "    while current_sparsity <= 0.20:\n",
    "        print(f\"  尝试保留比例：{current_sparsity:.1%}\")\n",
    "        threshold = np.percentile(energies, 100 * (1 - current_sparsity))\n",
    "        mask      = energies >= threshold\n",
    "        A_sk      = np.zeros_like(A_true)\n",
    "        A_sk[mask] = A_eff[mask]\n",
    "\n",
    "        rho_sk = np.max(np.abs(eigvals(A_sk)))\n",
    "\n",
    "        # 若谱半径为 0（DAG），尝试加入高能候选边修复\n",
    "        if rho_sk < 1e-9:\n",
    "            print(\"    骨架为 DAG，尝试修复回路...\")\n",
    "            cands = sorted(\n",
    "                [(energies[r, c], r, c)\n",
    "                 for r, c in zip(*np.where((energies > 1e-9) & (~mask)))],\n",
    "                reverse=True\n",
    "            )\n",
    "            rescued = False\n",
    "            A_tmp = A_sk.copy()\n",
    "            for i, (_, r, c) in enumerate(cands[:200]):\n",
    "                A_tmp[r, c] = A_eff[r, c]\n",
    "                if i % 10 == 0 and np.max(np.abs(eigvals(A_tmp))) > 1e-9:\n",
    "                    A_sk = A_tmp; rescued = True\n",
    "                    print(f\"    修复成功，共加入 {i+1} 条边。\")\n",
    "                    break\n",
    "            if not rescued:\n",
    "                current_sparsity += 0.01; continue\n",
    "\n",
    "        # 谱半径归一化\n",
    "        rho_sk = np.max(np.abs(eigvals(A_sk)))\n",
    "        if rho_sk > 1e-9:\n",
    "            A_skeleton = A_sk * (rho_true / rho_sk)\n",
    "            print(f\"  骨架锁定（保留比例 {current_sparsity:.1%}）。\")\n",
    "            break\n",
    "        current_sparsity += 0.01\n",
    "\n",
    "    if A_skeleton is None:\n",
    "        raise RuntimeError(\"无法在 20% 保留比例内构造有效骨架，请检查网络结构。\")\n",
    "\n",
    "    # 绝热插值：A_true → A_skeleton\n",
    "    mask_true     = np.abs(A_true)     > 1e-5\n",
    "    mask_sk       = np.abs(A_skeleton) > 1e-5\n",
    "    mask_backbone = mask_true & mask_sk\n",
    "    mask_redundant= mask_true & (~mask_sk)\n",
    "    mask_shortcut = mask_sk  & (~mask_true)\n",
    "\n",
    "    history = []\n",
    "    for t in range(steps + 1):\n",
    "        alpha   = t / steps\n",
    "        A_curr  = np.zeros_like(A_true)\n",
    "        A_curr[mask_redundant]  = A_true[mask_redundant]     * (1 - alpha)\n",
    "        A_curr[mask_shortcut]   = A_skeleton[mask_shortcut]  * alpha\n",
    "        A_curr[mask_backbone]   = (A_true[mask_backbone] * (1 - alpha) +\n",
    "                                   A_skeleton[mask_backbone] * alpha)\n",
    "        rho_c = np.max(np.abs(eigvals(A_curr)))\n",
    "        if rho_c > 1e-9:\n",
    "            A_curr *= (rho_true / rho_c)\n",
    "        history.append(A_curr.copy())\n",
    "\n",
    "    A_proxy = history[-1]\n",
    "    print(f\"稀疏化完成。A_proxy 边数：{np.sum(np.abs(A_proxy) > 1e-5)}\")\n",
    "    return A_proxy, history, A_skeleton\n",
    "\n",
    "\n",
    "def verify_sparsification_dynamics(history, model, X_train, X_obs, T_train_steps):\n",
    "    \"\"\"\n",
    "    验证稀疏化路径上每一步的矩阵是否保持动力学精度。\n",
    "\n",
    "    参数\n",
    "    ----\n",
