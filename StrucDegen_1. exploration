    "# ==============================================================\n",
    "# Cell 13：结构演化分析（稀疏化路径上的 Core & 结构相似度）\n",
    "# 对应原始 notebook 末尾的 analyze_ffcr_evolution\n",
    "# ==============================================================\n",
    "core_proxy = compute_core_matrix(A_proxy, U_dyn)\n",
    "\n",
    "sim_struct_true, sim_struct_hat  = [], []\n",
    "sim_core_true,   sim_core_hat    = [], []\n",
    "\n",
    "for A_step in history:\n",
    "    # 结构相似度\n",
    "    sim_struct_true.append(np.corrcoef(A_step.flatten(), A_true.flatten())[0, 1])\n",
    "    sim_struct_hat.append( np.corrcoef(A_step.flatten(), A_hat_best.flatten())[0, 1])\n",
    "    # Core 相似度\n",
    "    c_step = compute_core_matrix(A_step, U_dyn)\n",
    "    sim_core_true.append(np.corrcoef(c_step.flatten(), core_true.flatten())[0, 1])\n",
    "    sim_core_hat.append( np.corrcoef(c_step.flatten(), core_hat.flatten())[0, 1])\n",
    "\n",
    "steps_ax = list(range(len(history)))\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 5))\n",
    "\n",
    "axes[0].plot(steps_ax, sim_struct_true, 'k--o', alpha=0.7, label='与 A_true 结构相似度')\n",
    "axes[0].plot(steps_ax, sim_struct_hat,  'r-o',  label='与 A_hat 结构相似度')\n",
    "axes[0].set_title('稀疏化路径：结构演化'); axes[0].set_xlabel('步骤')\n",
    "axes[0].set_ylabel('Pearson 相关系数'); axes[0].legend(); axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "axes[1].plot(steps_ax, sim_core_true, 'k--o', alpha=0.7, label='与 core_true 相似度')\n",
    "axes[1].plot(steps_ax, sim_core_hat,  'r-o',  label='与 core_hat 相似度')\n",
    "axes[1].axhline(1.0, color='gray', ls=':', alpha=0.5)\n",
    "axes[1].set_title('稀疏化路径：动力学 Core 保真度'); axes[1].set_xlabel('步骤')\n",
    "axes[1].set_ylabel('Pearson 相关系数'); axes[1].legend(); axes[1].grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout(); plt.show()"
   ]
