    "# Cell 11：验证稀疏化路径的动力学保真度\n",
    "# ==============================================================\n",
    "print(\"\\n验证稀疏化路径各步骤的动力学精度...\")\n",
    "mae_list = verify_sparsification_dynamics(\n",
    "    history, model, X_train, X_obs, T_train\n",
    ")\n",
    "\n",
    "plot_sparsification_path(history, mae_list,\n",
    "                          title=\"稀疏化路径：动力学稳定性验证\",\n",
    "                          save_path=None)\n",
    "\n",
    "print(f\"\\n起点 MAE（A_true）  ：{mae_list[0]:.6f}\")\n",
    "print(f\"终点 MAE（A_proxy） ：{mae_list[-1]:.6f}\")\n",
    "print(f\"A_hat MAE           ：\", end=\"\")\n",
    "steps_pred = T_total - T_train\n",
    "X_hat_future = model.simulate(A_hat_best, T_steps=steps_pred, init_state=x0_pred)\n",
    "X_hat_full   = np.vstack([X_train, X_hat_future])\n",
    "_, mae_hat   = evaluate_prediction_accuracy(X_obs, X_hat_full, T_train)\n",
    "print(f\"{mae_hat:.6f}\")"
   ]
