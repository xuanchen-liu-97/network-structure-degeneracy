    "\n",
    "def compare_sparsification_algorithms(A_true, A_v1, A_v2,\n",
    "                                       X_obs, model, T_train_steps,\n",
    "                                       U_dyn, dyn_type='generic',\n",
    "                                       T_sim=500, seed=42,\n",
    "                                       save_path=None):\n",
    "    \"\"\"\n",
    "    对比 Algorithm 1（sparsify_network）和 Algorithm 2（sparsify_network_v2）\n",
    "    在同一个网络上的稀疏化结果，输出统计表并绘制对比图。\n",
    "\n",
    "    指标：边数、A_eff 偏差、ε_align、ε_macro、预测 MAE。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    A_true        : np.ndarray (N, N)  原始网络\n",
    "    A_v1          : np.ndarray (N, N)  Algorithm 1 输出\n",
    "    A_v2          : np.ndarray (N, N)  Algorithm 2 输出\n",
    "    X_obs         : np.ndarray (T, N)  完整观测轨迹\n",
    "    model         : NetworkDynamics\n",
    "    T_train_steps : int\n",
    "    U_dyn         : np.ndarray (N, k)\n",
    "    dyn_type      : str  见 compute_order_parameter\n",
    "    T_sim         : int  序参量模拟步数\n",
    "    seed          : int\n",
    "    save_path     : str or None\n",
    "    \"\"\"\n",
    "    A_eff_ref  = compute_effective_matrix(A_true, U_dyn)\n",
    "    init_state = X_obs[T_train_steps]\n",
    "    steps_pred = len(X_obs) - T_train_steps\n",
    "    X_train    = X_obs[:T_train_steps]\n",
    "\n",
    "    def _metrics(A_proxy, label):\n",
    "        # A_eff 偏差\n",
    "        A_eff_p = compute_effective_matrix(A_proxy, U_dyn)\n",
    "        delta   = (np.linalg.norm(A_eff_p - A_eff_ref, 'fro') /\n",
    "                   max(np.linalg.norm(A_eff_ref, 'fro'), 1e-12))\n",
    "        # 主奇异向量对齐度\n",
    "        eps_align, alignment, _, _ = compute_eigenvector_alignment(\n",
    "            A_true, A_proxy, k=1, mode='left'\n",
    "        )\n",
    "        # 序参量距离\n",
    "        eps_macro, phi_t, phi_p = compute_order_parameter_distance(\n",
    "            A_proxy, A_true, model, dyn_type=dyn_type,\n",
    "            T_steps=T_sim, seed=seed\n",
    "        )\n",
    "        # 预测 MAE\n",
    "        X_pred = model.simulate(A_proxy, T_steps=steps_pred, init_state=init_state)\n",
    "        X_full = np.vstack([X_train, X_pred])\n",
    "        _, mae = evaluate_prediction_accuracy(X_obs, X_full, T_train_steps)\n",
    "        n_edges = int(np.sum(np.abs(A_proxy) > 1e-5))\n",
    "        return {\"label\": label, \"edges\": n_edges, \"delta\": delta,\n",
    "                \"eps_align\": eps_align, \"eps_macro\": eps_macro, \"mae\": mae}\n",
    "\n",
    "    rows = [_metrics(A_v1, \"Algorithm 1\"), _metrics(A_v2, \"Algorithm 2\")]\n",
    "\n",
    "    # 打印统计表\n",
    "    print(f\"\\n{'':20s} {'边数':>6} {'δ(A_eff)':>10} {'ε_align':>9} {'ε_macro':>9} {'MAE':>9}\")\n",
    "    print(\"─\" * 68)\n",
    "    for r in rows:\n",
    "        print(f\"{r['label']:20s} {r['edges']:>6} {r['delta']:>10.4f} \"\n",
    "              f\"{r['eps_align']:>9.4f} {r['eps_macro']:>9.4f} {r['mae']:>9.6f}\")\n",
    "    n_orig = int(np.sum(np.abs(A_true) > 1e-5))\n",
    "    print(f\"{'A_true（基准）':20s} {n_orig:>6}\")\n",
    "\n",
    "    # 可视化对比\n",
    "    fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "    metric_names  = [\"δ (A_eff 偏差)\", \"ε_align（对齐距离）\", \"预测 MAE\"]\n",
    "    metric_keys   = [\"delta\", \"eps_align\", \"mae\"]\n",
    "    bar_colors    = [\"steelblue\", \"tomato\"]\n",
    "\n",
    "    for ax, name, key in zip(axes, metric_names, metric_keys):\n",
    "        vals   = [r[key] for r in rows]\n",
    "        labels = [r[\"label\"] for r in rows]\n",
    "        bars   = ax.bar(labels, vals, color=bar_colors, alpha=0.8, width=0.5)\n",
    "        ax.bar_label(bars, fmt=\"%.4f\", padding=3, fontsize=10)\n",
    "        ax.set_title(name); ax.set_ylabel(name); ax.grid(axis='y', alpha=0.3)\n",
    "\n",
    "    plt.suptitle(\"Algorithm 1 vs Algorithm 2 稀疏化效果对比\", fontsize=14)\n",
    "    plt.tight_layout()\n",
    "    _save_or_show(fig, save_path)\n",
    "    return rows\n",
    "\n",
    "\n",
    "def verify_sparsification_dynamics(history, model, X_train, X_obs, T_train_steps):\n",
    "    \"\"\"\n",
    "    验证稀疏化路径上每一步的矩阵是否保持动力学精度。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    history       : list of np.ndarray  由 sparsify_network 返回\n",
    "    model         : NetworkDynamics\n",
    "    X_train       : np.ndarray (T_train, N)\n",
    "    X_obs         : np.ndarray (T_total, N)  完整观测（Ground Truth）\n",
    "    T_train_steps : int\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    mae_list : list of float  各步的全局 MAE\n",
    "    \"\"\"\n",
    "    mae_list   = []\n",
    "    pred_steps = len(X_obs) - T_train_steps\n",
    "    init_state = X_obs[T_train_steps]\n",
    "\n",
    "    for i, A_curr in enumerate(history):\n",
    "        try:\n",
    "            X_sim  = model.simulate(A_curr, T_steps=pred_steps, init_state=init_state)\n",
    "            X_full = np.vstack([X_train, X_sim])\n",
    "            _, eps = evaluate_prediction_accuracy(X_obs, X_full, T_train_steps)\n",
    "            mae_list.append(eps)\n",
    "        except Exception as e:\n",
    "            print(f\"  步骤 {i}：模拟失败（{e}）\")\n",
    "            mae_list.append(np.inf)\n",
    "    return mae_list"
   ]
