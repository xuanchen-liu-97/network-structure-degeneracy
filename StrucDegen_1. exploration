    "def initialize_adjacency_matrix(matrix, seed=None):\n",
    "    \"\"\"\n",
    "    将邻接矩阵中所有 1 随机初始化为 [0.5, 1.5] 均匀分布的权重，0 保持不变。\n",
    "\n",
    "    参数\n",
    "    ----\n",
    "    matrix : array-like\n",
    "    seed   : int, optional\n",
    "\n",
    "    返回\n",
    "    ----\n",
    "    matrix : np.ndarray (float)\n",
    "    \"\"\"\n",
    "    if seed is not None:\n",
    "        np.random.seed(seed)\n",
    "    matrix = np.array(matrix, dtype=float)\n",
    "    mask = (matrix == 1)\n",
    "    matrix[mask] = np.random.uniform(0.5, 1.5, size=mask.sum())\n",
    "    return matrix"
   ]
